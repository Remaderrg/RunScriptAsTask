{
  "name": "runbatastask",
  "publisher": "Remader",
  "displayName": "Run Script As Task",
  "description": "Run .bat, .cmd, and .ps1 files in the terminal with one click",
  "version": "0.0.4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Remader/RunScriptAsTask.git",
    "directory": "runbatastask"
  },
  "bugs": {
    "url": "https://github.com/Remader/RunScriptAsTask/issues"
  },
  "homepage": "https://github.com/Remader/RunScriptAsTask#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onLanguage:bat", "onLanguage:powershell"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "runbatastask.runAsTask",
        "title": "Run as Task",
        "icon": "$(play)",
        "category": "Run Script"
      }
    ],
    "configuration": {
      "title": "Run Script As Task",
      "properties": {
        "runbatastask.reuseTerminal": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Reuse a single terminal tab for each run (**default**). When disabled, every run opens a new terminal."
        }
      }
    },
    "menus": {
      "commandPalette": [
        { "command": "runbatastask.runAsTask" }
      ],
      "editor/title/run": [
        {
          "when": "resourceExtname == '.bat' || resourceExtname == '.cmd' || resourceExtname == '.ps1'",
          "command": "runbatastask.runAsTask",
          "group": "1_run"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@vscode/vsce": "^3.6.1",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
